{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "msbuild Sysmon_analyzer.sln /p:Configuration=Debug /p:Platform=x64 ; if ($?) { .\\x64\\Debug\\Sysmon_analyzer.exe }",
            "options": {
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-Command"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}